# Deal Analyzer environment variables
# Copy this file to .env (or set these in your host/container environment)

# Server
PORT=3001

# IDX provider integration
IDX_API_BASE_URL=https://your-idx-provider.example.com/v1
IDX_API_KEY=replace-with-your-idx-api-key
IDX_API_KEY_HEADER=x-api-key
IDX_API_TIMEOUT_MS=10000

# Comparable search fallback behavior
# true  -> return sample properties when IDX is unavailable
# false -> return provider error/no results only
ENABLE_MOCK_COMPS=true
